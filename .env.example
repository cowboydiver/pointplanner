# Supabase project credentials. Copy this file to `.env` (or `.env.local`) and
# fill in the values from your Supabase project's API settings.
# These are public client-side keys; do NOT commit real values.
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key
