# Supabase — client-side config for the SPA.
# Copy this file to `.env.local` (gitignored via the *.local rule) and fill in
# the values from your Supabase project. Both are safe to expose in the browser
# bundle; access is enforced by Row-Level Security. See docs/supabase-setup.md.
#
# Find them in the Supabase dashboard:
#   Settings → API       → Project URL
#   Settings → API Keys  → "Publishable and secret API keys" tab → publishable key
#
# NEVER put a secret key (sb_secret_...) or the JWT secret behind a VITE_ prefix —
# Vite inlines every VITE_* var into the client bundle.

VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxxxx
